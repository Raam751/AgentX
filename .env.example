# LLM Provider: 'groq' or 'openai'
LLM_PROVIDER=groq

# Groq (default — free, get key at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (optional fallback)
OPENAI_API_KEY=your_openai_api_key_here

# Model (auto-selected based on provider if not set)
LLM_MODEL=

# Agent settings
HEADLESS=false
MAX_STEPS=20
PORT=3000

# Directories
SCREENSHOT_DIR=./screenshots
LOG_DIR=./logs
